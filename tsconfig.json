{
    "compilerOptions": {
        "target": "es2018",
        "module": "esnext",
        "strict": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "moduleResolution": "node",
        "resolveJsonModule": true,
        "baseUrl": ".",
        "noEmit": true,
        "skipLibCheck": true,
        "strictNullChecks": true,
        "allowJs": true,
        "paths": {
            "src/*": [
                "vendor/shopware/storefront/Resources/app/storefront/src/*"
            ]
        }
    },
    "include": [
        "custom/static-plugins/**/src/Resources/app/storefront/**/*.ts"
    ],
    "exclude": [
        "**/node_modules/**",
        "**/build/**",
        "**/dist/**",
        "**/public/**",
        "**/assets/**"
    ]
}
