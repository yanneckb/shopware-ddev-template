{
  "name": "Shopware6DefaultTheme",
  "author": "Shopware AG",
  "previewMedia": "app/storefront/dist/assets/defaultThemePreview.png",
  "views": [
     "@Storefront",
     "@Plugins",
     "@Shopware6DefaultTheme"
  ],
  "style": [
    "app/storefront/src/scss/overrides.scss",
    "@Storefront",
    "app/storefront/src/scss/base.scss"
  ],
  "script": [
    "@Storefront",
    "app/storefront/dist/storefront/js/shopware6-default-theme/shopware6-default-theme.js"
  ],
  "asset": [
    "@Storefront",
    "app/storefront/src/assets"
  ],
  "iconSets": {
    "default": "app/storefront/src/assets/icon/default",
    "solid": "app/storefront/src/assets/icon/solid"
  },
  "config": {
    "blocks": {
        "themeColors": {
            "label": {
                "en-GB": "Theme colours",
                "de-DE": "Theme-Farben"
            }
        },
        "typography": {
            "label": {
                "en-GB": "Typography",
                "de-DE": "Typografie"
            }
        },
        "eCommerce": {
            "label": {
                "en-GB": "E-Commerce",
                "de-DE": "E-Commerce"
            }
        },
        "statusColors": {
            "label": {
                "en-GB": "Status messages",
                "de-DE": "Status-Ausgaben"
            }
        },
        "media": {
            "label": {
                "en-GB": "Media",
                "de-DE": "Medien"
            }
        },
        "unordered": {
            "label": {
                "en-GB": "Misc",
                "de-DE": "Sonstige"
            }
        }
    },
    "fields": {
